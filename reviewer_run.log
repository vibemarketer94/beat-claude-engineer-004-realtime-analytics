| full_expected | 578.7 | 5787.0 | 5.79 | 1.5 | 6.08 | $96.0 | $1267.2 | $139.72 | $437.5 | $1250.0 | $930.0 | $15.0 | $2250.0 | $6385.43 | yes |
| large_payload | 578.7 | 5787.0 | 14.47 | 3.75 | 15.19 | $240.0 | $1584.0 | $349.31 | $437.5 | $1750.0 | $1240.0 | $37.5 | $2250.0 | $7888.31 | yes |
